# ---- App ----
PORT=3000

# Gate for the SAP admin page (/admin) where company challenges are created.
# Leave empty to keep /admin open (fine for local dev); set a strong value in
# production so only SAP staff can create challenges.
ADMIN_KEY=

# Database connection string used by Prisma + the app.
# For local dev pointing at the docker-compose Postgres (published on 5433 to
# avoid clashing with any Postgres you already run on 5432):
DATABASE_URL=postgresql://crc:crc@localhost:5433/crc

# ---- Challenge brief AI synthesis ----
# The challenge brief (/brief/[code]) is generated by a frontier Claude model
# from the de-identified evidence pack. Server-side only — never exposed to the
# client. If the key is absent or BRIEF_AI_DISABLED=1, the brief falls back to a
# deterministic, rules-based version (no AI), so the feature degrades gracefully.
ANTHROPIC_API_KEY=
# Model used for brief synthesis (default: claude-haiku-4-5). Swap to a larger
# model (e.g. claude-sonnet-4-6 / claude-opus-4-8) for higher-quality prose.
BRIEF_MODEL=claude-haiku-4-5
# Set to 1 to force the deterministic brief and skip the API entirely.
BRIEF_AI_DISABLED=

# ---- Postgres (used by docker-compose) ----
POSTGRES_USER=crc
POSTGRES_PASSWORD=crc
POSTGRES_DB=crc

# ---- Caddy reverse proxy (production on the VPS) ----
# Set to your real domain to get automatic HTTPS, e.g. challenge.example.com
# Leave as :80 for local / no-TLS testing.
DOMAIN=:80
