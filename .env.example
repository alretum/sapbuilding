# ---- App ----
PORT=3000

# Gate for the SAP admin page (/admin) where company challenges are created.
# Leave empty to keep /admin open (fine for local dev); set a strong value in
# production so only SAP staff can create challenges.
ADMIN_KEY=

# Database connection string used by Prisma + the app.
# For local dev pointing at the docker-compose Postgres (published on 5433 to
# avoid clashing with any Postgres you already run on 5432):
DATABASE_URL=postgresql://crc:crc@localhost:5433/crc

# ---- Postgres (used by docker-compose) ----
POSTGRES_USER=crc
POSTGRES_PASSWORD=crc
POSTGRES_DB=crc

# ---- Caddy reverse proxy (production on the VPS) ----
# Set to your real domain to get automatic HTTPS, e.g. challenge.example.com
# Leave as :80 for local / no-TLS testing.
DOMAIN=:80
