// Cloud Readiness Challenge — data model.
// Roles and actions live in /content (JSON), not the DB — they are the same for
// every session. Only session-specific facts are persisted here. Scores are
// always *derived* from action_completions (see src/lib/scoring.ts), never
// stored as mutable counters, so the live dashboard is always consistent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                String             @id @default(cuid())
  code              String             @unique // short join code, e.g. "K7Q2M"
  name              String
  status            String             @default("active") // lobby | active | finished
  involvedRoles     String[] // role ids (from content) participating in this session
  leaderboardPublic Boolean            @default(false) // opt-in: shown on public leaderboard + map only if true
  strictGate        Boolean            @default(false) // true = readiness gated on every dept participating
  // Location for the Germany readiness map (set by SAP at setup). Optional —
  // companies without a location simply don't appear on the map.
  regionCode        String? // ISO 3166-2 DE code, e.g. "DE-BY"
  city              String?
  lat               Float?
  lng               Float?
  isDemo            Boolean            @default(false) // seeded demo company (for the map)
  // Company profile for the personalized read (PR B). Pre-filled by SAP at setup,
  // confirmed by the decision-maker via the magic link (profileToken).
  industry          String?
  country           String?
  sapVersion        String?
  companySize       String?
  dataSensitivity   String?
  profileToken      String?            @unique
  profileConfirmedAt DateTime?
  createdAt         DateTime           @default(now())
  startedAt         DateTime?
  players           Player[]
  completions       ActionCompletion[]
  generatedBrief    GeneratedBrief?
}

// The challenge brief, generated on demand or auto-generated in the background
// once every participant has finished — so the decision-maker opens it instantly.
// `doc` is a validated BriefDoc (src/lib/brief-doc.ts). Regenerated only when the
// evidence-pack `inputHash` changes (someone played more). Additive table.
model GeneratedBrief {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inputHash   String // hash of the evidence pack → cache key
  status      String   @default("ready") // generating | ready | failed
  source      String   @default("baseline") // ai | baseline
  doc         Json // the validated BriefDoc
  model       String? // provenance: which model produced it
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Player {
  id          String             @id @default(cuid())
  sessionId   String
  session     Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String
  roleId      String // role id from content
  avatar      String?
  createdAt   DateTime           @default(now())
  completions ActionCompletion[]

  @@index([sessionId])
}

model ActionCompletion {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  actionId    String // action id from content
  roleId      String // denormalized from player for fast aggregation
  score       Int
  payload     Json? // raw answers/choices, for later analysis
  completedAt DateTime @default(now())

  @@unique([playerId, actionId]) // a player completes each action at most once
  @@index([sessionId])
}
